// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Place {
    id          Int      @id @default(autoincrement())
    name        String   @unique
    district    String
    state       String   @default("Lumbini")
    type        String // "Temple", "Hotel", "Restaurant", etc.
    latitude    Float?
    longitude   Float?
    description String?
    imageUrl    String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([district])
    @@index([type])
    @@index([state])
}
